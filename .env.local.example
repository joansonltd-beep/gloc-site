# Copy this file to `.env.local` and fill in your own values, then restart `npm run dev`.
# (.env.local is gitignored, so your real values never get committed.)

# Your WhatsApp Business number, full international form, digits only.
# Example for a Trinidad & Tobago number: 18681234567
NEXT_PUBLIC_WHATSAPP_NUMBER=1868XXXXXXX

# Where leads get sent. Paste an Airtable automation webhook URL, a Google
# Apps Script web-app URL, a Zapier/Make webhook, etc. Leave blank to skip
# capture (CTAs still open WhatsApp normally).
LEAD_WEBHOOK_URL=

# --- Sanity CMS (M4) ---
# From your Sanity project (sanity.io/manage, or after `npx sanity init`).
# Until these are set, the site uses the bundled default content.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
# Optional: pin the API version used for reads.
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01
# Write token (Editor/Deploy permissions) — ONLY needed to run `npm run seed`.
# Create at sanity.io/manage -> API -> Tokens. Keep it secret (server-only).
SANITY_API_WRITE_TOKEN=
